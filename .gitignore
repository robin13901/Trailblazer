# PMTiles assets — regenerated per developer via tool/fetch_pmtiles.sh
# See assets/tiles/README.md and .planning/STATE.md
assets/tiles/*.pmtiles

# Battery baseline — temporary start-of-drive snapshot (committed artifacts are
# docs/battery-baseline.md and docs/battery-baseline.json)
docs/.battery-baseline.tmp.json

# Local planning intel — regenerated by hooks, not tracked
.planning/intel/

# Generated code
**/*.g.dart
**/*.freezed.dart
**/*.drift.dart
/test/generated_migrations/

# Coverage
/coverage/

# Flutter build artifacts (belt-and-braces; flutter create adds most)
/build/
.dart_tool/

# Phase 4 pipeline scratch + outputs
tool/osm_pipeline/.dart_tool/
tool/osm_pipeline/build/
tool/osm_pipeline/out/
tool/osm_pipeline/**/*.osm.pbf
# ...except the hand-crafted tiny fixture used by pbf_reader_test.dart
!tool/osm_pipeline/test/fixtures/tiny.osm.pbf

# Personal API key file for --dart-define-from-file (MapTiler etc.)
# See env/dev.json.example for the shape. Real env/dev.json is gitignored.
env/dev.json
