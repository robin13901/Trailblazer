{
  "version": 8,
  "name": "Trailblazer Dark",
  "glyphs": "https://protomaps.github.io/basemaps-assets/fonts/{fontstack}/{range}.pbf",
  "sprite": null,
  "sources": {
    "trailblazer": {
      "type": "vector",
      "attribution": "© <a href='https://openstreetmap.org'>OpenStreetMap</a> contributors",
      "tiles": ["http://127.0.0.1:7070/{z}/{x}/{y}.pbf"],
      "minzoom": 0,
      "maxzoom": 12
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#0a1728"
      }
    },
    {
      "id": "water-fill",
      "type": "fill",
      "source": "trailblazer",
      "source-layer": "water",
      "filter": ["==", ["geometry-type"], "Polygon"],
      "paint": {
        "fill-color": "#061024",
        "fill-antialias": true
      }
    },
    {
      "id": "waterway-river",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "water",
      "minzoom": 7,
      "filter": [
        "all",
        ["==", ["geometry-type"], "LineString"],
        ["==", ["get", "kind"], "river"]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#22506e",
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 0.6, 12, 2.5, 16, 5]
      }
    },
    {
      "id": "waterway-canal",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "water",
      "minzoom": 9,
      "filter": [
        "all",
        ["==", ["geometry-type"], "LineString"],
        ["==", ["get", "kind"], "canal"]
      ],
      "layout": {
        "line-cap": "butt",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#1c4560",
        "line-width": ["interpolate", ["linear"], ["zoom"], 9, 0.4, 14, 1.5]
      }
    },
    {
      "id": "waterway-stream",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "water",
      "minzoom": 11,
      "filter": [
        "all",
        ["==", ["geometry-type"], "LineString"],
        ["==", ["get", "kind"], "stream"]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#183a52",
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 0.3, 15, 1.2]
      }
    },
    {
      "id": "admin-fill-l4",
      "type": "fill",
      "source": "trailblazer",
      "source-layer": "admin_boundaries",
      "filter": [
        "all",
        ["==", ["get", "shape"], "fill"],
        ["==", ["to-number", ["get", "admin_level"]], 4]
      ],
      "paint": {
        "fill-color": "#26241f",
        "fill-opacity": 0.2
      }
    },
    {
      "id": "admin-line-l2",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "admin_boundaries",
      "filter": [
        "all",
        ["==", ["get", "shape"], "outline"],
        ["==", ["to-number", ["get", "admin_level"]], 2]
      ],
      "paint": {
        "line-color": "#78715a",
        "line-width": 1.6,
        "line-opacity": 0.75
      }
    },
    {
      "id": "admin-line-l4",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "admin_boundaries",
      "filter": [
        "all",
        ["==", ["get", "shape"], "outline"],
        ["==", ["to-number", ["get", "admin_level"]], 4]
      ],
      "paint": {
        "line-color": "#5a5240",
        "line-width": 1.2,
        "line-dasharray": [3, 2],
        "line-opacity": 0.7
      }
    },
    {
      "id": "admin-line-l6",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "admin_boundaries",
      "minzoom": 6,
      "filter": [
        "all",
        ["==", ["get", "shape"], "outline"],
        ["==", ["to-number", ["get", "admin_level"]], 6]
      ],
      "paint": {
        "line-color": "#4a4432",
        "line-width": 0.8,
        "line-dasharray": [2, 2],
        "line-opacity": 0.6
      }
    },
    {
      "id": "admin-line-l8",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "admin_boundaries",
      "minzoom": 9,
      "filter": [
        "all",
        ["==", ["get", "shape"], "outline"],
        ["==", ["to-number", ["get", "admin_level"]], 8]
      ],
      "paint": {
        "line-color": "#3a3628",
        "line-width": 0.5,
        "line-dasharray": [2, 3],
        "line-opacity": 0.5
      }
    },
    {
      "id": "road-path",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "roads",
      "minzoom": 12,
      "filter": ["==", ["get", "kind"], "path"],
      "layout": {
        "line-cap": "butt",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#3a3a44",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.4, 16, 1.5],
        "line-dasharray": [1, 2]
      }
    },
    {
      "id": "road-track",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "roads",
      "minzoom": 12,
      "filter": ["==", ["get", "kind"], "track"],
      "layout": {
        "line-cap": "butt",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#4a4436",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.5, 16, 2],
        "line-dasharray": [2, 1]
      }
    },
    {
      "id": "road-minor-casing",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "roads",
      "minzoom": 12,
      "filter": ["in", ["get", "kind"], ["literal", ["minor", "other"]]],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#1a2a44",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 1.5, 16, 5]
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "roads",
      "minzoom": 12,
      "filter": ["in", ["get", "kind"], ["literal", ["minor", "other"]]],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#3a4d6b",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.8, 16, 3.5]
      }
    },
    {
      "id": "road-tertiary",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "roads",
      "minzoom": 10,
      "filter": ["==", ["get", "kind"], "tertiary"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#8a7a4a",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.6, 15, 4, 18, 10]
      }
    },
    {
      "id": "road-secondary",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "roads",
      "minzoom": 9,
      "filter": ["==", ["get", "kind"], "secondary"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#b28c3c",
        "line-width": ["interpolate", ["linear"], ["zoom"], 9, 0.9, 15, 5, 18, 12]
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "roads",
      "minzoom": 7,
      "filter": ["==", ["get", "kind"], "primary"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#d99230",
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 0.9, 14, 5, 18, 14]
      }
    },
    {
      "id": "road-trunk",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "roads",
      "minzoom": 6,
      "filter": ["==", ["get", "kind"], "trunk"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#e8a038",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 1, 14, 5.5, 18, 15]
      }
    },
    {
      "id": "road-motorway",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "roads",
      "minzoom": 5,
      "filter": ["==", ["get", "kind"], "motorway"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#f0b040",
        "line-width": ["interpolate", ["linear"], ["zoom"], 5, 1, 12, 4, 16, 10, 18, 16]
      }
    },
    {
      "id": "label-place-city",
      "type": "symbol",
      "source": "trailblazer",
      "source-layer": "labels",
      "minzoom": 4,
      "maxzoom": 14,
      "filter": ["==", ["get", "kind"], "place_city"],
      "layout": {
        "text-field": ["get", "name"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 5, 11, 10, 15, 14, 18],
        "text-font": ["Noto Sans Medium"],
        "text-max-width": 10,
        "symbol-sort-key": ["-", 100000000, ["to-number", ["get", "population"], 0]]
      },
      "paint": {
        "text-color": "#cfd8e0",
        "text-halo-color": "#0a1728",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "label-place-town",
      "type": "symbol",
      "source": "trailblazer",
      "source-layer": "labels",
      "minzoom": 8,
      "filter": ["==", ["get", "kind"], "place_town"],
      "layout": {
        "text-field": ["get", "name"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 10, 14, 14],
        "text-font": ["Noto Sans Regular"],
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#b0bcc8",
        "text-halo-color": "#0a1728",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "label-place-village",
      "type": "symbol",
      "source": "trailblazer",
      "source-layer": "labels",
      "minzoom": 10,
      "filter": ["==", ["get", "kind"], "place_village"],
      "layout": {
        "text-field": ["get", "name"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 10, 14, 12],
        "text-font": ["Noto Sans Regular"],
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#96a4b0",
        "text-halo-color": "#0a1728",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "label-place-suburb",
      "type": "symbol",
      "source": "trailblazer",
      "source-layer": "labels",
      "minzoom": 11,
      "filter": ["==", ["get", "kind"], "place_suburb"],
      "layout": {
        "text-field": ["get", "name"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 11, 10, 14, 13],
        "text-font": ["Noto Sans Regular"],
        "text-max-width": 8,
        "text-transform": "uppercase",
        "text-letter-spacing": 0.05
      },
      "paint": {
        "text-color": "#7a8896",
        "text-halo-color": "#0a1728",
        "text-halo-width": 1
      }
    },
    {
      "id": "label-road-shield",
      "type": "symbol",
      "source": "trailblazer",
      "source-layer": "labels",
      "minzoom": 8,
      "filter": [
        "all",
        ["==", ["get", "kind"], "road_shield"],
        ["has", "ref"]
      ],
      "layout": {
        "text-field": ["get", "ref"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 10, 14, 12],
        "text-font": ["Noto Sans Medium"],
        "text-max-width": 4,
        "text-padding": 2
      },
      "paint": {
        "text-color": "#e8a038",
        "text-halo-color": "#0a1728",
        "text-halo-width": 1.5
      }
    }
  ]
}
