{
  "version": 8,
  "name": "Trailblazer Light",
  "glyphs": "https://protomaps.github.io/basemaps-assets/fonts/{fontstack}/{range}.pbf",
  "sprite": null,
  "sources": {
    "trailblazer": {
      "type": "vector",
      "attribution": "© <a href='https://openstreetmap.org'>OpenStreetMap</a> contributors",
      "tiles": ["http://127.0.0.1:7070/{z}/{x}/{y}.pbf"],
      "minzoom": 0,
      "maxzoom": 12
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f2f1ef"
      }
    },
    {
      "id": "water-fill",
      "type": "fill",
      "source": "trailblazer",
      "source-layer": "water",
      "filter": ["==", ["geometry-type"], "Polygon"],
      "paint": {
        "fill-color": "#a8d5e5",
        "fill-antialias": true
      }
    },
    {
      "id": "waterway-river",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "water",
      "minzoom": 7,
      "filter": [
        "all",
        ["==", ["geometry-type"], "LineString"],
        ["==", ["get", "kind"], "river"]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#a8d5e5",
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 0.6, 12, 2.5, 16, 5]
      }
    },
    {
      "id": "waterway-canal",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "water",
      "minzoom": 9,
      "filter": [
        "all",
        ["==", ["geometry-type"], "LineString"],
        ["==", ["get", "kind"], "canal"]
      ],
      "layout": {
        "line-cap": "butt",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#a8d5e5",
        "line-width": ["interpolate", ["linear"], ["zoom"], 9, 0.4, 14, 1.5]
      }
    },
    {
      "id": "waterway-stream",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "water",
      "minzoom": 11,
      "filter": [
        "all",
        ["==", ["geometry-type"], "LineString"],
        ["==", ["get", "kind"], "stream"]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#c0dcea",
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 0.3, 15, 1.2]
      }
    },
    {
      "id": "admin-fill-l4",
      "type": "fill",
      "source": "trailblazer",
      "source-layer": "admin_boundaries",
      "filter": [
        "all",
        ["==", ["get", "shape"], "fill"],
        ["==", ["to-number", ["get", "admin_level"]], 4]
      ],
      "paint": {
        "fill-color": "#e8e4df",
        "fill-opacity": 0.15
      }
    },
    {
      "id": "admin-line-l2",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "admin_boundaries",
      "filter": [
        "all",
        ["==", ["get", "shape"], "outline"],
        ["==", ["to-number", ["get", "admin_level"]], 2]
      ],
      "paint": {
        "line-color": "#8a8478",
        "line-width": 1.6,
        "line-opacity": 0.8
      }
    },
    {
      "id": "admin-line-l4",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "admin_boundaries",
      "filter": [
        "all",
        ["==", ["get", "shape"], "outline"],
        ["==", ["to-number", ["get", "admin_level"]], 4]
      ],
      "paint": {
        "line-color": "#a8a294",
        "line-width": 1.2,
        "line-dasharray": [3, 2],
        "line-opacity": 0.7
      }
    },
    {
      "id": "admin-line-l6",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "admin_boundaries",
      "minzoom": 6,
      "filter": [
        "all",
        ["==", ["get", "shape"], "outline"],
        ["==", ["to-number", ["get", "admin_level"]], 6]
      ],
      "paint": {
        "line-color": "#bab4a4",
        "line-width": 0.8,
        "line-dasharray": [2, 2],
        "line-opacity": 0.6
      }
    },
    {
      "id": "admin-line-l8",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "admin_boundaries",
      "minzoom": 9,
      "filter": [
        "all",
        ["==", ["get", "shape"], "outline"],
        ["==", ["to-number", ["get", "admin_level"]], 8]
      ],
      "paint": {
        "line-color": "#c8c4bd",
        "line-width": 0.5,
        "line-dasharray": [2, 3],
        "line-opacity": 0.5
      }
    },
    {
      "id": "road-path",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "roads",
      "minzoom": 12,
      "filter": ["==", ["get", "kind"], "path"],
      "layout": {
        "line-cap": "butt",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#c8c0b0",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.4, 16, 1.5],
        "line-dasharray": [1, 2]
      }
    },
    {
      "id": "road-track",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "roads",
      "minzoom": 12,
      "filter": ["==", ["get", "kind"], "track"],
      "layout": {
        "line-cap": "butt",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#c8c0a8",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.5, 16, 2],
        "line-dasharray": [2, 1]
      }
    },
    {
      "id": "road-minor-casing",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "roads",
      "minzoom": 12,
      "filter": ["in", ["get", "kind"], ["literal", ["minor", "other"]]],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#e0dcd6",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 1.5, 16, 5]
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "roads",
      "minzoom": 12,
      "filter": ["in", ["get", "kind"], ["literal", ["minor", "other"]]],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#ffffff",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.8, 16, 3.5]
      }
    },
    {
      "id": "road-tertiary",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "roads",
      "minzoom": 10,
      "filter": ["==", ["get", "kind"], "tertiary"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#f0e8d0",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.6, 15, 4, 18, 10]
      }
    },
    {
      "id": "road-secondary",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "roads",
      "minzoom": 9,
      "filter": ["==", ["get", "kind"], "secondary"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#f5e0a8",
        "line-width": ["interpolate", ["linear"], ["zoom"], 9, 0.9, 15, 5, 18, 12]
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "roads",
      "minzoom": 7,
      "filter": ["==", ["get", "kind"], "primary"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#ffd280",
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 0.9, 14, 5, 18, 14]
      }
    },
    {
      "id": "road-trunk",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "roads",
      "minzoom": 6,
      "filter": ["==", ["get", "kind"], "trunk"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#f7be5c",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 1, 14, 5.5, 18, 15]
      }
    },
    {
      "id": "road-motorway",
      "type": "line",
      "source": "trailblazer",
      "source-layer": "roads",
      "minzoom": 5,
      "filter": ["==", ["get", "kind"], "motorway"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#eda04a",
        "line-width": ["interpolate", ["linear"], ["zoom"], 5, 1, 12, 4, 16, 10, 18, 16]
      }
    },
    {
      "id": "label-place-city",
      "type": "symbol",
      "source": "trailblazer",
      "source-layer": "labels",
      "minzoom": 4,
      "maxzoom": 14,
      "filter": ["==", ["get", "kind"], "place_city"],
      "layout": {
        "text-field": ["get", "name"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 5, 11, 10, 15, 14, 18],
        "text-font": ["Noto Sans Medium"],
        "text-max-width": 10,
        "symbol-sort-key": ["-", 100000000, ["to-number", ["get", "population"], 0]]
      },
      "paint": {
        "text-color": "#333",
        "text-halo-color": "#f2f1ef",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "label-place-town",
      "type": "symbol",
      "source": "trailblazer",
      "source-layer": "labels",
      "minzoom": 8,
      "filter": ["==", ["get", "kind"], "place_town"],
      "layout": {
        "text-field": ["get", "name"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 10, 14, 14],
        "text-font": ["Noto Sans Regular"],
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#444",
        "text-halo-color": "#f2f1ef",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "label-place-village",
      "type": "symbol",
      "source": "trailblazer",
      "source-layer": "labels",
      "minzoom": 10,
      "filter": ["==", ["get", "kind"], "place_village"],
      "layout": {
        "text-field": ["get", "name"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 10, 14, 12],
        "text-font": ["Noto Sans Regular"],
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#666",
        "text-halo-color": "#f2f1ef",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "label-place-suburb",
      "type": "symbol",
      "source": "trailblazer",
      "source-layer": "labels",
      "minzoom": 11,
      "filter": ["==", ["get", "kind"], "place_suburb"],
      "layout": {
        "text-field": ["get", "name"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 11, 10, 14, 13],
        "text-font": ["Noto Sans Regular"],
        "text-max-width": 8,
        "text-transform": "uppercase",
        "text-letter-spacing": 0.05
      },
      "paint": {
        "text-color": "#777",
        "text-halo-color": "#f2f1ef",
        "text-halo-width": 1
      }
    },
    {
      "id": "label-road-shield",
      "type": "symbol",
      "source": "trailblazer",
      "source-layer": "labels",
      "minzoom": 8,
      "filter": [
        "all",
        ["==", ["get", "kind"], "road_shield"],
        ["has", "ref"]
      ],
      "layout": {
        "text-field": ["get", "ref"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 10, 14, 12],
        "text-font": ["Noto Sans Medium"],
        "text-max-width": 4,
        "text-padding": 2
      },
      "paint": {
        "text-color": "#8a5a2a",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    }
  ]
}
