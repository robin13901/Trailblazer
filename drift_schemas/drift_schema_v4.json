  "fixed_sql": [
    {
      "name": "trips",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"trips\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"started_at\" INTEGER NOT NULL, \"ended_at\" INTEGER NULL, \"duration_seconds\" INTEGER NULL, \"distance_meters\" REAL NULL, \"avg_speed_kmh\" REAL NULL, \"max_speed_kmh\" REAL NULL, \"status\" TEXT NOT NULL DEFAULT 'pending', \"manually_started\" INTEGER NOT NULL DEFAULT 0 CHECK (\"manually_started\" IN (0, 1)), \"auto_stopped\" INTEGER NOT NULL DEFAULT 0 CHECK (\"auto_stopped\" IN (0, 1)), \"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), \"bbox_min_lat\" REAL NULL, \"bbox_min_lon\" REAL NULL, \"bbox_max_lat\" REAL NULL, \"bbox_max_lon\" REAL NULL, \"point_count\" INTEGER NULL);"
        }
      ]
    },
    {
      "name": "trip_points",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"trip_points\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"trip_id\" INTEGER NOT NULL REFERENCES trips (id) ON DELETE CASCADE, \"seq\" INTEGER NOT NULL, \"ts\" INTEGER NOT NULL, \"lat\" REAL NOT NULL, \"lon\" REAL NOT NULL, \"speed_kmh\" REAL NULL, \"accuracy_meters\" REAL NULL, \"altitude_meters\" REAL NULL, \"motion_type\" TEXT NULL, UNIQUE (\"trip_id\", \"seq\"));"
        }
      ]
    },
    {
      "name": "driven_way_intervals",
      "sql": [
